<Page x:Class="ParfumAdmin_WPF.Views.Pages.ProductsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Loaded="Page_Loaded"
      Background="#1E1E2E">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Fejléc -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Termékkezelés"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="White"/>
            <TextBlock Text="Termékek listázása, szerkesztése és törlése"
                       FontSize="13"
                       Foreground="#888"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Kereső és gombok -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="13"
                     Padding="12,10"
                     Background="#2A2A3E"
                     Foreground="White"
                     BorderBrush="#444"
                     BorderThickness="1"
                     Margin="0,0,12,0">
                <TextBox.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </TextBox.Resources>
            </TextBox>

            <Button Grid.Column="1"
                    Content="🔍 Keresés"
                    Command="{Binding SearchCommand}"
                    Padding="16,10"
                    Background="#2A2A3E"
                    Foreground="White"
                    BorderThickness="0"
                    Margin="0,0,8,0"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Grid.Column="2"
                    Content="🗑 Törlés"
                    Command="{Binding DeleteProductCommand}"
                    Padding="16,10"
                    Background="#DC2626"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>

        </Grid>

        <!-- Töltés jelző -->
        <TextBlock Grid.Row="2"
                   Text="Betöltés..."
                   Foreground="#888"
                   FontSize="14"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- Hibaüzenet -->
        <TextBlock Grid.Row="2"
                   Text="{Binding ErrorMessage}"
                   Foreground="#FF6B6B"
                   FontSize="14"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>

        <!-- Termékek táblázata -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Products}"
                  SelectedItem="{Binding SelectedProduct}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Background="#2A2A3E"
                  Foreground="White"
                  BorderBrush="#444"
                  BorderThickness="1"
                  RowBackground="#2A2A3E"
                  AlternatingRowBackground="#252535"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#333"
                  SelectionMode="Single"
                  CanUserResizeRows="False"
                  HeadersVisibility="Column"
                  Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibilityConverter}}">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#16162A"/>
                    <Setter Property="Foreground" Value="#AAA"/>
                    <Setter Property="Padding" Value="12,10"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="BorderBrush" Value="#333"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Foreground" Value="White"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#3D2B6B"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#2E2E4E"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"
                                    Binding="{Binding Id}"
                                    Width="50"/>
                <DataGridTextColumn Header="Név"
                                    Binding="{Binding Name}"
                                    Width="*"/>
                <DataGridTextColumn Header="Kategória"
                                    Binding="{Binding Category.Name}"
                                    Width="140"/>
                <DataGridTextColumn Header="Ár"
                                    Binding="{Binding Price, StringFormat={}{0:N0} Ft}"
                                    Width="100"/>
                <DataGridTextColumn Header="Készlet"
                                    Binding="{Binding StockQuantity}"
                                    Width="80"/>
                <DataGridTextColumn Header="Méret"
                                    Binding="{Binding VolumeML}"
                                    Width="80"/>
                <DataGridTextColumn Header="Nem"
                                    Binding="{Binding Gender}"
                                    Width="80"/>
                <DataGridCheckBoxColumn Header="Aktív"
                                        Binding="{Binding IsActive}"
                                        Width="60"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Lapozó -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,16,0,0">

            <Button Content="← Előző"
                    Command="{Binding PreviousPageCommand}"
                    Padding="16,8"
                    Background="#2A2A3E"
                    Foreground="White"
                    BorderThickness="0"
                    Margin="0,0,8,0"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>

            <TextBlock VerticalAlignment="Center"
                       Margin="0,0,8,0"
                       Foreground="#AAA"
                       FontSize="13">
                <Run Text="{Binding CurrentPage}"/>
                <Run Text=" / "/>
                <Run Text="{Binding TotalPages}"/>
            </TextBlock>

            <Button Content="Következő →"
                    Command="{Binding NextPageCommand}"
                    Padding="16,8"
                    Background="#2A2A3E"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>

        </StackPanel>

    </Grid>
</Page>