<Page x:Class="ParfumAdmin_WPF.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1E1E2E"
      Loaded="Page_Loaded">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Fejléc -->
            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <TextBlock Text="Dashboard"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="White"/>
                <TextBlock Text="Áttekintés és analitikai adatok"
                           FontSize="13"
                           Foreground="#888"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Töltés jelző -->
            <TextBlock Grid.Row="1"
                       Text="Adatok betöltése..."
                       Foreground="#888"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       Margin="0,40,0,0"
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- Stat kártyák -->
            <UniformGrid Grid.Row="1"
                         Rows="1" Columns="3"
                         Margin="0,0,0,24"
                         Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibilityConverter}}">

                <!-- Mai látogatók -->
                <Border Background="#2A2A3E" CornerRadius="10" Margin="0,0,12,0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="👁 Mai látogatók"
                                   Foreground="#888"
                                   FontSize="12"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding TodayPageviews}"
                                   Foreground="White"
                                   FontSize="32"
                                   FontWeight="Bold"/>
                        <TextBlock Text="oldalmegtekintés ma"
                                   Foreground="#666"
                                   FontSize="11"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Mai sessionök -->
                <Border Background="#2A2A3E" CornerRadius="10" Margin="6,0,6,0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="👤 Mai sessionök"
                                   Foreground="#888"
                                   FontSize="12"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding TodaySessions}"
                                   Foreground="White"
                                   FontSize="32"
                                   FontWeight="Bold"/>
                        <TextBlock Text="egyedi látogató ma"
                                   Foreground="#666"
                                   FontSize="11"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Aktív felhasználók -->
                <Border Background="#3D2B6B" CornerRadius="10" Margin="12,0,0,0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="⚡ Aktív most"
                                   Foreground="#C4B5FD"
                                   FontSize="12"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding ActiveSessions}"
                                   Foreground="White"
                                   FontSize="32"
                                   FontWeight="Bold"/>
                        <TextBlock Text="aktív az elmúlt 5 percben"
                                   Foreground="#9D8FBF"
                                   FontSize="11"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

            </UniformGrid>

            <!-- Második sor kártyák -->
            <UniformGrid Grid.Row="2"
                         Rows="1" Columns="3"
                         Margin="0,0,0,24"
                         Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibilityConverter}}">

                <!-- Heti látogatók -->
                <Border Background="#2A2A3E" CornerRadius="10" Margin="0,0,12,0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="📅 Heti látogatók"
                                   Foreground="#888"
                                   FontSize="12"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding WeekPageviews}"
                                   Foreground="White"
                                   FontSize="32"
                                   FontWeight="Bold"/>
                        <TextBlock Text="elmúlt 7 nap"
                                   Foreground="#666"
                                   FontSize="11"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Heti új látogatók -->
                <Border Background="#2A2A3E" CornerRadius="10" Margin="6,0,6,0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="🆕 Új látogatók"
                                   Foreground="#888"
                                   FontSize="12"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding WeekNewVisitors}"
                                   Foreground="White"
                                   FontSize="32"
                                   FontWeight="Bold"/>
                        <TextBlock Text="elmúlt 7 nap"
                                   Foreground="#666"
                                   FontSize="11"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Havi látogatók -->
                <Border Background="#2A2A3E" CornerRadius="10" Margin="12,0,0,0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="📊 Havi látogatók"
                                   Foreground="#888"
                                   FontSize="12"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding MonthPageviews}"
                                   Foreground="White"
                                   FontSize="32"
                                   FontWeight="Bold"/>
                        <TextBlock Text="elmúlt 30 nap"
                                   Foreground="#666"
                                   FontSize="11"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

            </UniformGrid>

            <!-- Top termékek -->
            <Border Grid.Row="3"
                    Background="#2A2A3E"
                    CornerRadius="10"
                    Padding="20"
                    Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="🏆 Top 10 legtöbbet megtekintett termék (elmúlt 30 nap)"
                               Foreground="White"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,0,0,16"/>

                    <DataGrid ItemsSource="{Binding TopProducts}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Background="Transparent"
                              Foreground="White"
                              BorderThickness="0"
                              RowBackground="Transparent"
                              AlternatingRowBackground="#252535"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#333"
                              CanUserResizeRows="False"
                              HeadersVisibility="Column">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#AAA"/>
                                <Setter Property="Padding" Value="8,8"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="BorderBrush" Value="#333"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Foreground" Value="White"/>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Termék"
                                                Binding="{Binding Product.Name}"
                                                Width="*"/>
                            <DataGridTextColumn Header="Kategória"
                                                Binding="{Binding Product.Category.Name}"
                                                Width="140"/>
                            <DataGridTextColumn Header="Ár"
                                                Binding="{Binding Product.Price, StringFormat={}{0:N0} Ft}"
                                                Width="100"/>
                            <DataGridTextColumn Header="Megtekintések"
                                                Binding="{Binding ViewCount}"
                                                Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

        </Grid>
    </ScrollViewer>
</Page>
