<Page x:Class="ParfumAdmin_WPF.Views.Pages.OrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1E1E2E"
      Loaded="Page_Loaded">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Fejléc -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Rendeléskezelés"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="White"/>
            <TextBlock Text="Rendelések listázása és státusz kezelése"
                       FontSize="13"
                       Foreground="#888"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Szűrő -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,0,0,16">
            <TextBlock Text="Szűrés státusz szerint:"
                       Foreground="#AAA"
                       FontSize="13"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0"/>
            <ComboBox ItemsSource="{Binding StatusOptions}"
                      SelectedItem="{Binding SelectedStatus}"
                      FontSize="13"
                      Padding="12,8"
                      Width="160"
                      Background="#2A2A3E"
                      Foreground="White"
                      BorderBrush="#444"/>
        </StackPanel>

        <!-- Töltés jelző -->
        <TextBlock Grid.Row="2"
                   Text="Betöltés..."
                   Foreground="#888"
                   FontSize="14"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- Hibaüzenet -->
        <TextBlock Grid.Row="2"
                   Text="{Binding ErrorMessage}"
                   Foreground="#FF6B6B"
                   FontSize="14"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>

        <!-- Rendelések táblázata -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Orders}"
                  SelectedItem="{Binding SelectedOrder}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Background="#2A2A3E"
                  Foreground="White"
                  BorderBrush="#444"
                  BorderThickness="1"
                  RowBackground="#2A2A3E"
                  AlternatingRowBackground="#252535"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#333"
                  SelectionMode="Single"
                  CanUserResizeRows="False"
                  HeadersVisibility="Column"
                  Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibilityConverter}}">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#16162A"/>
                    <Setter Property="Foreground" Value="#AAA"/>
                    <Setter Property="Padding" Value="12,10"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="BorderBrush" Value="#333"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Foreground" Value="White"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#3D2B6B"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#2E2E4E"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"
                                    Binding="{Binding Id}"
                                    Width="50"/>
                <DataGridTextColumn Header="Vásárló"
                                    Binding="{Binding User.Name}"
                                    Width="*"/>
                <DataGridTextColumn Header="Összeg"
                                    Binding="{Binding TotalAmount, StringFormat={}{0:N0} Ft}"
                                    Width="110"/>
                <DataGridTextColumn Header="Státusz"
                                    Binding="{Binding Status}"
                                    Width="110"/>
                <DataGridTextColumn Header="Fizetés"
                                    Binding="{Binding PaymentStatus}"
                                    Width="110"/>
                <DataGridTextColumn Header="Tételek"
                                    Binding="{Binding ItemsCount}"
                                    Width="70"/>
                <DataGridTextColumn Header="Dátum"
                                    Binding="{Binding CreatedAt}"
                                    Width="130"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Státusz módosítás -->
        <Border Grid.Row="3"
                Background="#2A2A3E"
                CornerRadius="8"
                Padding="16"
                Margin="0,16,0,0"
                Visibility="{Binding SelectedOrder, Converter={StaticResource NullToVisibilityConverter}}">
            <StackPanel>
                <TextBlock Text="Kiválasztott rendelés státuszának módosítása"
                           Foreground="#AAA"
                           FontSize="12"
                           Margin="0,0,0,12"/>
                <StackPanel Orientation="Horizontal">
                    <Button Content="pending"
                            Command="{Binding UpdateStatusCommand}"
                            CommandParameter="pending"
                            Style="{StaticResource StatusButtonStyle}"/>
                    <Button Content="processing"
                            Command="{Binding UpdateStatusCommand}"
                            CommandParameter="processing"
                            Style="{StaticResource StatusButtonStyle}"/>
                    <Button Content="shipped"
                            Command="{Binding UpdateStatusCommand}"
                            CommandParameter="shipped"
                            Style="{StaticResource StatusButtonStyle}"/>
                    <Button Content="arrived"
                            Command="{Binding UpdateStatusCommand}"
                            CommandParameter="arrived"
                            Style="{StaticResource StatusButtonStyle}"/>
                    <Button Content="canceled"
                            Command="{Binding UpdateStatusCommand}"
                            CommandParameter="canceled"
                            Style="{StaticResource StatusButtonStyle}"/>
                    <Button Content="refunded"
                            Command="{Binding UpdateStatusCommand}"
                            CommandParameter="refunded"
                            Style="{StaticResource StatusButtonStyle}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Lapozó -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,16,0,0">

            <Button Content="← Előző"
                    Command="{Binding PreviousPageCommand}"
                    Padding="16,8"
                    Background="#2A2A3E"
                    Foreground="White"
                    BorderThickness="0"
                    Margin="0,0,8,0"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>

            <TextBlock VerticalAlignment="Center"
                       Margin="0,0,8,0"
                       Foreground="#AAA"
                       FontSize="13">
                <Run Text="{Binding CurrentPage}"/>
                <Run Text=" / "/>
                <Run Text="{Binding TotalPages}"/>
            </TextBlock>

            <Button Content="Következő →"
                    Command="{Binding NextPageCommand}"
                    Padding="16,8"
                    Background="#2A2A3E"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>

        </StackPanel>

    </Grid>
</Page>
