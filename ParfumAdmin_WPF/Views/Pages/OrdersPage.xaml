<Page x:Class="ParfumAdmin_WPF.Views.Pages.OrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1E1E2E"
      Loaded="Page_Loaded">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Fejléc -->
            <RowDefinition Height="Auto"/>   <!-- Szűrők + gombok -->
            <RowDefinition Height="*"/>      <!-- DataGrid -->
            <RowDefinition Height="Auto"/>   <!-- Szerkesztés panel -->
            <RowDefinition Height="Auto"/>   <!-- Lapozó -->
        </Grid.RowDefinitions>

        <!-- Fejléc -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Rendeléskezelés"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="White"/>
            <TextBlock Text="Rendelések listázása, státusz és fizetés kezelése"
                       FontSize="13"
                       Foreground="#888"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Szűrők + gombok -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Státusz szűrő -->
            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                <TextBlock Text="Státusz"
                           Foreground="#AAA"
                           FontSize="12"
                           Margin="0,0,0,6"/>
                <ComboBox ItemsSource="{Binding StatusOptions}"
                          SelectedItem="{Binding SelectedStatus}"/>
            </StackPanel>

            <!-- Keresés -->
            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                <TextBlock Text="Keresés (vásárló neve vagy email)"
                           Foreground="#AAA"
                           FontSize="12"
                           Margin="0,0,0,6"/>
                <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="13"
                         Padding="12,10"
                         Background="#2A2A3E"
                         Foreground="White"
                         BorderBrush="#444"
                         BorderThickness="1">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
            </StackPanel>

            <!-- Szűrők törlése gomb -->
            <Button Grid.Column="2"
                    Content="♻ Szűrők törlése"
                    Command="{Binding ResetFiltersCommand}"
                    Padding="16,10"
                    Background="#2A2A3E"
                    Foreground="White"
                    BorderThickness="0"
                    Margin="0,0,8,0"
                    VerticalAlignment="Bottom"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>

            <!-- Törlés gomb -->
            <Button Grid.Column="3"
                    Content="🗑 Törlés"
                    Command="{Binding DeleteOrderCommand}"
                    Padding="16,10"
                    Foreground="White"
                    BorderThickness="0"
                    VerticalAlignment="Bottom"
                    Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#DC2626"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="6"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#B91C1C"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#4A1F1F"/>
                                <Setter Property="Foreground" Value="#888"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <!-- Töltés jelző -->
        <TextBlock Grid.Row="2"
                   Text="Betöltés..."
                   Foreground="#888"
                   FontSize="14"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- Hibaüzenet -->
        <TextBlock Grid.Row="2"
                   Text="{Binding ErrorMessage}"
                   Foreground="#FF6B6B"
                   FontSize="14"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>

        <!-- Rendelések táblázata -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Orders}"
                  SelectedItem="{Binding SelectedOrder}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Background="#2A2A3E"
                  Foreground="White"
                  BorderBrush="#444"
                  BorderThickness="1"
                  RowBackground="#2A2A3E"
                  AlternatingRowBackground="#252535"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#333"
                  SelectionMode="Single"
                  CanUserResizeRows="False"
                  CanUserResizeColumns="True"
                  HeadersVisibility="Column"
                  Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                  Sorting="DataGrid_Sorting">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#16162A"/>
                    <Setter Property="Foreground" Value="#AAA"/>
                    <Setter Property="Padding" Value="12,10"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="BorderBrush" Value="#333"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridColumnHeader">
                                <Grid>
                                    <Thumb x:Name="PART_LeftHeaderGripper" HorizontalAlignment="Left" Width="8" Cursor="SizeWE">
                                        <Thumb.Template><ControlTemplate TargetType="Thumb"><Border Background="Transparent"/></ControlTemplate></Thumb.Template>
                                    </Thumb>

                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            Padding="{TemplateBinding Padding}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ContentPresenter Grid.Column="0"
                                                              VerticalAlignment="Center"
                                                              HorizontalAlignment="Left"/>
                                            <TextBlock x:Name="SortArrow"
                                                       Grid.Column="1"
                                                       Margin="6,0,0,0"
                                                       FontSize="11"
                                                       VerticalAlignment="Center"
                                                       Foreground="#7C3AED"
                                                       Text=""/>
                                        </Grid>
                                    </Border>

                                    <Thumb x:Name="PART_RightHeaderGripper" HorizontalAlignment="Right" Width="8" Cursor="SizeWE">
                                        <Thumb.Template><ControlTemplate TargetType="Thumb"><Border Background="Transparent"/></ControlTemplate></Thumb.Template>
                                    </Thumb>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="SortDirection" Value="Ascending">
                                        <Setter TargetName="SortArrow" Property="Text" Value="▲"/>
                                    </Trigger>
                                    <Trigger Property="SortDirection" Value="Descending">
                                        <Setter TargetName="SortArrow" Property="Text" Value="▼"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Foreground" Value="White"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#3D2B6B"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#2E2E4E"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"
                                    Binding="{Binding Id}"
                                    Width="50"/>
                <DataGridTextColumn Header="Vásárló"
                                    Binding="{Binding User.Name}"
                                    Width="*"
                                    MinWidth="180"/>
                <DataGridTextColumn Header="Email"
                                    Binding="{Binding User.Email}"
                                    Width="190"/>
                <DataGridTextColumn Header="Összeg"
                                    Binding="{Binding TotalAmount, StringFormat={}{0:N0} Ft}"
                                    Width="110"/>
                <DataGridTextColumn Header="Státusz"
                                    Binding="{Binding Status}"
                                    Width="110"/>
                <DataGridTextColumn Header="Fizetés"
                                    Binding="{Binding PaymentStatus}"
                                    Width="110"/>
                <DataGridTextColumn Header="Tételek"
                                    Binding="{Binding ItemsCount}"
                                    Width="70"/>
                <DataGridTextColumn Header="Dátum"
                                    Binding="{Binding CreatedAt}"
                                    Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Szerkesztés panel — csak ha ki van választva egy sor -->
        <Border Grid.Row="3"
                Background="#1A1A2E"
                CornerRadius="8"
                BorderBrush="#333"
                BorderThickness="1"
                Padding="16"
                Margin="0,12,0,0"
                Visibility="{Binding SelectedOrder, Converter={StaticResource NullToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Fejléc -->
                <TextBlock Grid.Row="0"
                           Text="Kiválasztott rendelés módosítása"
                           Foreground="White"
                           FontWeight="SemiBold"
                           FontSize="13"
                           Margin="0,0,0,10"/>

                <!-- Rendelés státusz -->
                <StackPanel Grid.Row="1" Margin="0,0,0,10">
                    <TextBlock Text="Rendelés státusza"
                               Foreground="#AAA"
                               FontSize="11"
                               Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="pending"
                                Command="{Binding UpdateStatusCommand}"
                                CommandParameter="pending"
                                Background="{Binding SelectedOrder.Status, Converter={StaticResource StatusMatchToBrushConverter}, ConverterParameter=pending}"
                                Style="{StaticResource StatusButtonStyle}"/>
                        <Button Content="processing"
                                Command="{Binding UpdateStatusCommand}"
                                CommandParameter="processing"
                                Background="{Binding SelectedOrder.Status, Converter={StaticResource StatusMatchToBrushConverter}, ConverterParameter=processing}"
                                Style="{StaticResource StatusButtonStyle}"/>
                        <Button Content="shipped"
                                Command="{Binding UpdateStatusCommand}"
                                CommandParameter="shipped"
                                Background="{Binding SelectedOrder.Status, Converter={StaticResource StatusMatchToBrushConverter}, ConverterParameter=shipped}"
                                Style="{StaticResource StatusButtonStyle}"/>
                        <Button Content="arrived"
                                Command="{Binding UpdateStatusCommand}"
                                CommandParameter="arrived"
                                Background="{Binding SelectedOrder.Status, Converter={StaticResource StatusMatchToBrushConverter}, ConverterParameter=arrived}"
                                Style="{StaticResource StatusButtonStyle}"/>
                        <Button Content="canceled"
                                Command="{Binding UpdateStatusCommand}"
                                CommandParameter="canceled"
                                Background="{Binding SelectedOrder.Status, Converter={StaticResource StatusMatchToBrushConverter}, ConverterParameter=canceled}"
                                Style="{StaticResource StatusButtonStyle}"/>
                        <Button Content="refunded"
                                Command="{Binding UpdateStatusCommand}"
                                CommandParameter="refunded"
                                Background="{Binding SelectedOrder.Status, Converter={StaticResource StatusMatchToBrushConverter}, ConverterParameter=refunded}"
                                Style="{StaticResource StatusButtonStyle}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Fizetési státusz -->
                <StackPanel Grid.Row="2">
                    <TextBlock Text="Fizetési státusz"
                               Foreground="#AAA"
                               FontSize="11"
                               Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="pending"
                                Command="{Binding UpdatePaymentCommand}"
                                CommandParameter="pending"
                                Background="{Binding SelectedOrder.PaymentStatus, Converter={StaticResource StatusMatchToBrushConverter}, ConverterParameter=pending}"
                                Style="{StaticResource StatusButtonStyle}"/>
                        <Button Content="processing"
                                Command="{Binding UpdatePaymentCommand}"
                                CommandParameter="processing"
                                Background="{Binding SelectedOrder.PaymentStatus, Converter={StaticResource StatusMatchToBrushConverter}, ConverterParameter=processing}"
                                Style="{StaticResource StatusButtonStyle}"/>
                        <Button Content="paid"
                                Command="{Binding UpdatePaymentCommand}"
                                CommandParameter="paid"
                                Background="{Binding SelectedOrder.PaymentStatus, Converter={StaticResource StatusMatchToBrushConverter}, ConverterParameter=paid}"
                                Style="{StaticResource StatusButtonStyle}"/>
                        <Button Content="failed"
                                Command="{Binding UpdatePaymentCommand}"
                                CommandParameter="failed"
                                Background="{Binding SelectedOrder.PaymentStatus, Converter={StaticResource StatusMatchToBrushConverter}, ConverterParameter=failed}"
                                Style="{StaticResource StatusButtonStyle}"/>
                        <Button Content="refunded"
                                Command="{Binding UpdatePaymentCommand}"
                                CommandParameter="refunded"
                                Background="{Binding SelectedOrder.PaymentStatus, Converter={StaticResource StatusMatchToBrushConverter}, ConverterParameter=refunded}"
                                Style="{StaticResource StatusButtonStyle}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Lapozó -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,16,0,0">

            <Button Content="← Előző"
                    Command="{Binding PreviousPageCommand}"
                    Padding="16,8"
                    Background="#2A2A3E"
                    Foreground="White"
                    BorderThickness="0"
                    Margin="0,0,8,0"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>

            <TextBlock VerticalAlignment="Center"
                       Margin="0,0,8,0"
                       Foreground="#AAA"
                       FontSize="13">
                <Run Text="{Binding CurrentPage}"/>
                <Run Text=" / "/>
                <Run Text="{Binding TotalPages}"/>
            </TextBlock>

            <Button Content="Következő →"
                    Command="{Binding NextPageCommand}"
                    Padding="16,8"
                    Background="#2A2A3E"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>

        </StackPanel>

    </Grid>
</Page>
