<Page x:Class="ParfumAdmin_WPF.Views.Pages.AnalyticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ctl="clr-namespace:ParfumAdmin_WPF.Views.Controls"
      Background="#1E1E2E"
      Loaded="Page_Loaded">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Fejléc -->
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Analitika"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="Részletes grafikonok és trendek"
                               FontSize="13"
                               Foreground="#888"
                               Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="↻ Frissítés"
                        Command="{Binding RefreshCommand}"
                        Padding="14,8"/>
            </Grid>

            <!-- Hibaüzenet -->
            <TextBlock Grid.Row="1"
                       Text="{Binding ErrorMessage}"
                       Foreground="#F87171"
                       Margin="0,0,0,16"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>

            <!-- Töltés -->
            <TextBlock Grid.Row="1"
                       Text="Adatok betöltése..."
                       Foreground="#888"
                       HorizontalAlignment="Center"
                       Margin="0,40,0,0"
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- KPI összegző sor (periódus választóval) -->
            <Grid Grid.Row="2"
                  Margin="0,0,0,20"
                  Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Ma pageviews -->
                <Border Grid.Column="0" Background="#2A2A3E" CornerRadius="10" Margin="0,0,8,0" Padding="18">
                    <StackPanel>
                        <TextBlock Text="Ma – Oldalmegtekintés" Foreground="#888" FontSize="11"/>
                        <TextBlock Text="{Binding Overview.Today.Pageviews}" Foreground="White" FontSize="26" FontWeight="Bold" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Ma sessions -->
                <Border Grid.Column="1" Background="#2A2A3E" CornerRadius="10" Margin="4,0,4,0" Padding="18">
                    <StackPanel>
                        <TextBlock Text="Ma – Sessionök" Foreground="#888" FontSize="11"/>
                        <TextBlock Text="{Binding Overview.Today.UniqueSessions}" Foreground="White" FontSize="26" FontWeight="Bold" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Ma orders -->
                <Border Grid.Column="2" Background="#2A2A3E" CornerRadius="10" Margin="4,0,4,0" Padding="18">
                    <StackPanel>
                        <TextBlock Text="Ma – Rendelések" Foreground="#888" FontSize="11"/>
                        <TextBlock Text="{Binding Overview.Today.Orders}" Foreground="White" FontSize="26" FontWeight="Bold" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Ma revenue -->
                <Border Grid.Column="3" Background="#3D2B6B" CornerRadius="10" Margin="8,0,0,0" Padding="18">
                    <StackPanel>
                        <TextBlock Text="Ma – Bevétel" Foreground="#C4B5FD" FontSize="11"/>
                        <TextBlock Text="{Binding Overview.Today.Revenue, StringFormat={}{0:N0} Ft}" Foreground="White" FontSize="26" FontWeight="Bold" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Napi idősor -->
            <Border Grid.Row="3"
                    Background="#2A2A3E"
                    CornerRadius="10"
                    Padding="20"
                    Margin="0,0,0,20"
                    Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="📈 Napi idősor"
                                   Foreground="White"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding MetricOptions}"
                                  SelectedItem="{Binding SelectedMetric, Mode=TwoWay}"
                                  Width="170"
                                  Margin="0,0,8,0"/>
                        <ComboBox Grid.Column="2"
                                  ItemsSource="{Binding DaysOptions}"
                                  SelectedItem="{Binding SelectedDays, Mode=TwoWay}"
                                  Width="80">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StringFormat={}{0} nap}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>
                    <ctl:LineChart x:Name="DailyChart" Height="260"/>
                </StackPanel>
            </Border>

            <!-- Óránkénti + Eszköz típusok -->
            <Grid Grid.Row="4"
                  Margin="0,0,0,20"
                  Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Óránkénti -->
                <Border Grid.Column="0"
                        Background="#2A2A3E"
                        CornerRadius="10"
                        Padding="20"
                        Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="⏱ Óránkénti forgalom (ma)"
                                   Foreground="White"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,16"/>
                        <ctl:BarChart x:Name="HourlyChart" Height="220"/>
                    </StackPanel>
                </Border>

                <!-- Eszköz típusok (horizontális sávok) -->
                <Border Grid.Column="1"
                        Background="#2A2A3E"
                        CornerRadius="10"
                        Padding="20"
                        Margin="10,0,0,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="📱 Eszköz típusok (30 nap)"
                                       Foreground="White"
                                       FontSize="14"
                                       FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1"
                                       x:Name="DeviceTotalText"
                                       Foreground="#888"
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <StackPanel x:Name="DevicePanel" MinHeight="210"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Konverziós tölcsér -->
            <Border Grid.Row="5"
                    Background="#2A2A3E"
                    CornerRadius="10"
                    Padding="20"
                    Margin="0,0,0,20"
                    Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="🔻 Konverziós tölcsér (30 nap)"
                               Foreground="White"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,0,0,16"/>

                    <StackPanel x:Name="FunnelPanel"/>
                </StackPanel>
            </Border>

        </Grid>
    </ScrollViewer>
</Page>
