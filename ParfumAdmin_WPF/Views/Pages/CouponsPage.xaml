<Page x:Class="ParfumAdmin_WPF.Views.Pages.CouponsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Loaded="Page_Loaded"
      Background="#1E1E2E">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Fejléc -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Kuponkezelés"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="White"/>
            <TextBlock Text="Globális kuponok létrehozása, szerkesztése és törlése"
                       FontSize="13"
                       Foreground="#888"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Szűrők -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                <TextBlock Text="Típus"
                           Foreground="#AAA"
                           FontSize="12"
                           Margin="0,0,0,6"/>
                <ComboBox ItemsSource="{Binding DiscountTypeOptions}"
                          SelectedItem="{Binding SelectedDiscountType}"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                <TextBlock Text="Állapot"
                           Foreground="#AAA"
                           FontSize="12"
                           Margin="0,0,0,6"/>
                <ComboBox ItemsSource="{Binding StatusOptions}"
                          SelectedItem="{Binding SelectedStatus}"/>
            </StackPanel>

            <Button Grid.Column="2"
                    Content="♻ Szűrők törlése"
                    Command="{Binding ResetFiltersCommand}"
                    Padding="16,8"
                    Background="#2A2A3E"
                    Foreground="White"
                    BorderThickness="0"
                    VerticalAlignment="Bottom"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>

        <!-- Kereső és gombok -->
        <Grid Grid.Row="2" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                <TextBlock Text="Keresés (kuponkód)"
                           Foreground="#AAA"
                           FontSize="12"
                           Margin="0,0,0,6"/>
                <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="13"
                         Padding="12,10"
                         Background="#2A2A3E"
                         Foreground="White"
                         BorderBrush="#444"
                         BorderThickness="1">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
            </StackPanel>

            <Button Grid.Column="1"
                    Content="➕ Hozzáadás"
                    Command="{Binding AddCouponCommand}"
                    Padding="16,10"
                    Foreground="White"
                    BorderThickness="0"
                    Margin="0,0,8,0"
                    VerticalAlignment="Bottom"
                    Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#16A34A"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#15803D"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Grid.Column="2"
                    Content="✏ Szerkesztés"
                    Command="{Binding EditCouponCommand}"
                    Padding="16,10"
                    Foreground="White"
                    BorderThickness="0"
                    Margin="0,0,8,0"
                    VerticalAlignment="Bottom"
                    Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#2563EB"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#1E2A4A"/>
                                <Setter Property="Foreground" Value="#888"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Grid.Column="3"
                    Content="🗑 Törlés"
                    Command="{Binding DeleteCouponCommand}"
                    Padding="16,10"
                    Foreground="White"
                    BorderThickness="0"
                    VerticalAlignment="Bottom"
                    Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#DC2626"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#B91C1C"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#4A1F1F"/>
                                <Setter Property="Foreground" Value="#888"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <!-- Töltés jelző -->
        <TextBlock Grid.Row="3"
                   Text="Betöltés..."
                   Foreground="#888"
                   FontSize="14"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- Hibaüzenet -->
        <TextBlock Grid.Row="3"
                   Text="{Binding ErrorMessage}"
                   Foreground="#FF6B6B"
                   FontSize="14"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>

        <!-- Kuponok táblázata -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding Coupons}"
                  SelectedItem="{Binding SelectedCoupon}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Background="#2A2A3E"
                  Foreground="White"
                  BorderBrush="#444"
                  BorderThickness="1"
                  RowBackground="#2A2A3E"
                  AlternatingRowBackground="#252535"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#333"
                  SelectionMode="Single"
                  CanUserResizeRows="False"
                  CanUserResizeColumns="True"
                  HeadersVisibility="Column"
                  Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                  Sorting="DataGrid_Sorting">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#16162A"/>
                    <Setter Property="Foreground" Value="#AAA"/>
                    <Setter Property="Padding" Value="12,10"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="BorderBrush" Value="#333"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridColumnHeader">
                                <Grid>
                                    <Thumb x:Name="PART_LeftHeaderGripper" HorizontalAlignment="Left" Width="8" Cursor="SizeWE">
                                        <Thumb.Template><ControlTemplate TargetType="Thumb"><Border Background="Transparent"/></ControlTemplate></Thumb.Template>
                                    </Thumb>

                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            Padding="{TemplateBinding Padding}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ContentPresenter Grid.Column="0"
                                                              VerticalAlignment="Center"
                                                              HorizontalAlignment="Left"/>
                                            <TextBlock x:Name="SortArrow"
                                                       Grid.Column="1"
                                                       Margin="6,0,0,0"
                                                       FontSize="11"
                                                       VerticalAlignment="Center"
                                                       Foreground="#7C3AED"
                                                       Text=""/>
                                        </Grid>
                                    </Border>

                                    <Thumb x:Name="PART_RightHeaderGripper" HorizontalAlignment="Right" Width="8" Cursor="SizeWE">
                                        <Thumb.Template><ControlTemplate TargetType="Thumb"><Border Background="Transparent"/></ControlTemplate></Thumb.Template>
                                    </Thumb>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="SortDirection" Value="Ascending">
                                        <Setter TargetName="SortArrow" Property="Text" Value="▲"/>
                                    </Trigger>
                                    <Trigger Property="SortDirection" Value="Descending">
                                        <Setter TargetName="SortArrow" Property="Text" Value="▼"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Foreground" Value="White"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#3D2B6B"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#2E2E4E"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"
                                    Binding="{Binding Id}"
                                    Width="50"/>
                <DataGridTextColumn Header="Kuponkód"
                                    Binding="{Binding CouponCode}"
                                    Width="*"/>
                <DataGridTextColumn Header="Típus"
                                    Binding="{Binding DiscountType}"
                                    Width="110"/>
                <DataGridTextColumn Header="Érték"
                                    Binding="{Binding FormattedValue}"
                                    Width="100"/>
                <DataGridTextColumn Header="Lejárat"
                                    Binding="{Binding ExpiryDate, StringFormat=yyyy.MM.dd}"
                                    Width="110"/>
                <DataGridTextColumn Header="Felhasználás"
                                    Binding="{Binding UsageText}"
                                    Width="110"/>
                <DataGridTextColumn Header="Állapot"
                                    Binding="{Binding StatusText}"
                                    Width="90"/>
                <DataGridTemplateColumn Header="Aktív" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsActive, Mode=OneWay}"
                                      IsHitTestVisible="False"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Lapozó -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,16,0,0">

            <Button Content="← Előző"
                    Command="{Binding PreviousPageCommand}"
                    Padding="16,8"
                    Background="#2A2A3E"
                    Foreground="White"
                    BorderThickness="0"
                    Margin="0,0,8,0"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>

            <TextBlock VerticalAlignment="Center"
                       Margin="0,0,8,0"
                       Foreground="#AAA"
                       FontSize="13">
                <Run Text="{Binding CurrentPage}"/>
                <Run Text=" / "/>
                <Run Text="{Binding TotalPages}"/>
            </TextBlock>

            <Button Content="Következő →"
                    Command="{Binding NextPageCommand}"
                    Padding="16,8"
                    Background="#2A2A3E"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>

        </StackPanel>

    </Grid>
</Page>
