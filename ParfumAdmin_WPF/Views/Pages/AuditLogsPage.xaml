<Page x:Class="ParfumAdmin_WPF.Views.Pages.AuditLogsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1E1E2E"
      Loaded="Page_Loaded">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Fejléc -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Audit napló"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="White"/>
            <TextBlock Text="Adminisztrátori műveletek előzménye"
                       FontSize="13"
                       Foreground="#888"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Szűrők -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                <TextBlock Text="Művelet"
                           Foreground="#AAA"
                           FontSize="12"
                           Margin="0,0,0,6"/>
                <ComboBox ItemsSource="{Binding ActionOptions}"
                          SelectedItem="{Binding SelectedAction}"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                <TextBlock Text="Típus"
                           Foreground="#AAA"
                           FontSize="12"
                           Margin="0,0,0,6"/>
                <ComboBox ItemsSource="{Binding ModelTypeOptions}"
                          SelectedItem="{Binding SelectedModelType}"/>
            </StackPanel>

            <Button Grid.Column="2"
                    Content="♻ Szűrők törlése"
                    Command="{Binding ResetFiltersCommand}"
                    Padding="16,8"
                    Background="#2A2A3E"
                    Foreground="White"
                    BorderThickness="0"
                    VerticalAlignment="Bottom"
                    Margin="0,0,8,0"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Grid.Column="3"
                    Content="🔄 Frissítés"
                    Command="{Binding RefreshCommand}"
                    Padding="16,8"
                    Background="#2A2A3E"
                    Foreground="White"
                    BorderThickness="0"
                    VerticalAlignment="Bottom"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>

        <!-- Keresés -->
        <StackPanel Grid.Row="2" Margin="0,0,0,16">
            <TextBlock Text="Keresés (leírás vagy admin név)"
                       Foreground="#AAA"
                       FontSize="12"
                       Margin="0,0,0,6"/>
            <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="13"
                     Padding="12,10"
                     Background="#2A2A3E"
                     Foreground="White"
                     BorderBrush="#444"
                     BorderThickness="1">
                <TextBox.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </TextBox.Resources>
            </TextBox>
        </StackPanel>

        <!-- Töltés jelző -->
        <TextBlock Grid.Row="3"
                   Text="Betöltés..."
                   Foreground="#888"
                   FontSize="14"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- Hibaüzenet -->
        <TextBlock Grid.Row="3"
                   Text="{Binding ErrorMessage}"
                   Foreground="#FF6B6B"
                   FontSize="14"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>

        <!-- Napló táblázat -->
        <!-- ScrollViewer.*ScrollBarVisibility="Disabled": ld. DashboardPage.xaml
             kommentje — a DataGrid belső ScrollViewer-e ne villanjon fel a
             rendezés / layout-újraszámolás közben. -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding Logs}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Background="#2A2A3E"
                  Foreground="White"
                  BorderBrush="#444"
                  BorderThickness="1"
                  RowBackground="#2A2A3E"
                  AlternatingRowBackground="#252535"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#333"
                  SelectionMode="Single"
                  CanUserResizeRows="False"
                  CanUserResizeColumns="True"
                  HeadersVisibility="Column"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  ScrollViewer.VerticalScrollBarVisibility="Disabled"
                  Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibilityConverter}}">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#16162A"/>
                    <Setter Property="Foreground" Value="#AAA"/>
                    <Setter Property="Padding" Value="12,10"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="BorderBrush" Value="#333"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Foreground" Value="White"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#3D2B6B"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#2E2E4E"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Dátum"
                                    Binding="{Binding CreatedAt}"
                                    Width="170"/>

                <DataGridTextColumn Header="Admin"
                                    Binding="{Binding UserName}"
                                    Width="160"/>

                <DataGridTemplateColumn Header="Művelet" Width="140"
                                        SortMemberPath="Action">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Background="{Binding Action, Converter={StaticResource ActionToColorConverter}}"
                                    CornerRadius="10"
                                    Padding="10,3"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding Action}"
                                           Foreground="White"
                                           FontWeight="Bold"
                                           FontSize="11"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Típus"
                                    Binding="{Binding ModelType}"
                                    Width="90"/>

                <DataGridTextColumn Header="Rekord ID"
                                    Binding="{Binding ModelId}"
                                    Width="90"/>

                <DataGridTextColumn Header="Leírás"
                                    Binding="{Binding Description}"
                                    Width="*"
                                    MinWidth="250"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Lapozó -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,16,0,0">

            <Button Content="← Előző"
                    Command="{Binding PreviousPageCommand}"
                    Padding="16,8"
                    Background="#2A2A3E"
                    Foreground="White"
                    BorderThickness="0"
                    Margin="0,0,8,0"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>

            <TextBlock VerticalAlignment="Center"
                       Margin="0,0,8,0"
                       Foreground="#AAA"
                       FontSize="13">
                <Run Text="{Binding CurrentPage}"/>
                <Run Text=" / "/>
                <Run Text="{Binding TotalPages}"/>
            </TextBlock>

            <Button Content="Következő →"
                    Command="{Binding NextPageCommand}"
                    Padding="16,8"
                    Background="#2A2A3E"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Page>
