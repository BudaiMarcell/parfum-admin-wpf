<Window x:Class="ParfumAdmin_WPF.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Parfum Admin – Bejelentkezés"
        Height="450" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1E1E2E">

    <Grid>
        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Width="300">

            <!-- Logo / Cím -->
            <TextBlock Text="🌸 Parfum Admin"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8"/>

            <TextBlock Text="Jelentkezz be a folytatáshoz"
                       FontSize="13"
                       Foreground="#888"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,32"/>

            <!-- Email -->
            <TextBlock Text="Email cím"
                       Foreground="#AAA"
                       FontSize="12"
                       Margin="0,0,0,6"/>
            <TextBox x:Name="EmailBox"
                     Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="14"
                     Padding="12,10"
                     Background="#2A2A3E"
                     Foreground="White"
                     BorderBrush="#444"
                     BorderThickness="1"
                     Margin="0,0,0,16">
                <TextBox.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </TextBox.Resources>
            </TextBox>

            <!-- Jelszó -->
            <TextBlock Text="Jelszó"
                       Foreground="#AAA"
                       FontSize="12"
                       Margin="0,0,0,6"/>
            <PasswordBox x:Name="PasswordBox"
                         FontSize="14"
                         Padding="12,10"
                         Background="#2A2A3E"
                         Foreground="White"
                         BorderBrush="#444"
                         BorderThickness="1"
                         Margin="0,0,0,8">
                <PasswordBox.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </PasswordBox.Resources>
            </PasswordBox>

            <!-- Hibaüzenet -->
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#FF6B6B"
                       FontSize="12"
                       Margin="0,0,0,16"
                       TextWrapping="Wrap"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>

            <!-- Bejelentkezés gomb -->
            <Button Content="Bejelentkezés"
                    Command="{Binding LoginCommand}"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Padding="0,12"
                    Background="#7C3AED"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#7C3AED"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="0,12"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#6D28D9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#444"/>
                                <Setter Property="Foreground" Value="#888"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <!-- Töltés jelző -->
            <TextBlock Text="Bejelentkezés folyamatban..."
                       Foreground="#888"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       Margin="0,12,0,0"
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>

        </StackPanel>
    </Grid>
</Window>
