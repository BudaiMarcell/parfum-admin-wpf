<Window x:Class="ParfumAdmin_WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Parfum Admin Panel"
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Bal oldali navigáció -->
        <Border Grid.Column="0" Background="#16162A" BorderBrush="#2A2A3E" BorderThickness="0,0,1,0">
            <StackPanel>

                <!-- Logo -->
                <StackPanel Margin="20,30,20,40">
                    <TextBlock Text="🌸 Parfum"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="Admin Panel"
                               FontSize="12"
                               Foreground="#7C3AED"/>
                </StackPanel>

                <!-- Navigációs gombok -->
                <Button Content="📊  Dashboard"
                        Tag="Dashboard"
                        Click="NavButton_Click"
                        Style="{StaticResource NavButtonStyle}"/>

                <Button Content="🧴  Termékek"
                        Tag="Products"
                        Click="NavButton_Click"
                        Style="{StaticResource NavButtonStyle}"/>

                <Button Content="📦  Rendelések"
                        Tag="Orders"
                        Click="NavButton_Click"
                        Style="{StaticResource NavButtonStyle}"/>

                <!-- Kijelentkezés -->
                <Button Content="🚪  Kijelentkezés"
                        Click="LogoutButton_Click"
                        Margin="12,300,12,0"
                        Style="{StaticResource NavButtonStyle}"/>

            </StackPanel>
        </Border>

        <!-- Jobb oldali tartalom -->
        <Frame x:Name="MainFrame"
               Grid.Column="1"
               NavigationUIVisibility="Hidden"
               Background="#1E1E2E"/>

    </Grid>
</Window>