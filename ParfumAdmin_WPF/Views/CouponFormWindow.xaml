<Window x:Class="ParfumAdmin_WPF.Views.CouponFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        Height="600" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E2E">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="{Binding WindowTitle}"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="White"/>
            <TextBlock Text="{Binding Subtitle}"
                       FontSize="12"
                       Foreground="#888"
                       Margin="0,4,0,0"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <TextBlock Text="Kuponkód" Foreground="#AAA" FontSize="12" Margin="0,0,0,6"/>
                <TextBox Text="{Binding CouponCode, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="13" Padding="10,8"
                         Background="#2A2A3E" Foreground="White"
                         BorderBrush="#444" BorderThickness="1"
                         Margin="0,0,0,14">
                    <TextBox.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                    </TextBox.Resources>
                </TextBox>

                <TextBlock Text="Kedvezmény típusa *" Foreground="#AAA" FontSize="12" Margin="0,0,0,6"/>
                <ComboBox ItemsSource="{Binding DiscountTypeOptions}"
                          SelectedItem="{Binding SelectedDiscountType}"
                          Margin="0,0,0,14"/>

                <TextBlock Text="Kedvezmény értéke *" Foreground="#AAA" FontSize="12" Margin="0,0,0,6"/>
                <TextBox Text="{Binding DiscountValue, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="13" Padding="10,8"
                         Background="#2A2A3E" Foreground="White"
                         BorderBrush="#444" BorderThickness="1"
                         Margin="0,0,0,4">
                    <TextBox.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                    </TextBox.Resources>
                </TextBox>
                <TextBlock Text="Százalékos: 0-100; Fix: Ft összeg"
                           Foreground="#666" FontSize="11" Margin="0,0,0,14"/>

                <TextBlock Text="Lejárati dátum *" Foreground="#AAA" FontSize="12" Margin="0,0,0,6"/>
                <DatePicker SelectedDate="{Binding ExpiryDate}"
                            FontSize="13"
                            Margin="0,0,0,14"/>

                <TextBlock Text="Felhasználási limit" Foreground="#AAA" FontSize="12" Margin="0,0,0,6"/>
                <TextBox Text="{Binding UsageLimit, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                         FontSize="13" Padding="10,8"
                         Background="#2A2A3E" Foreground="White"
                         BorderBrush="#444" BorderThickness="1"
                         Margin="0,0,0,4">
                    <TextBox.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                    </TextBox.Resources>
                </TextBox>
                <TextBlock Text="Üresen hagyva korlátlan felhasználás"
                           Foreground="#666" FontSize="11" Margin="0,0,0,14"/>

                <CheckBox Content="Aktív"
                          IsChecked="{Binding IsActive}"
                          Foreground="White"
                          FontSize="13"
                          Margin="0,0,0,8"/>

            </StackPanel>
        </ScrollViewer>

        <TextBlock Grid.Row="2"
                   Text="{Binding ErrorMessage}"
                   Foreground="#FF6B6B"
                   FontSize="12"
                   Margin="0,12,0,0"
                   TextWrapping="Wrap"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">

            <Button Content="Mégsem"
                    Command="{Binding CancelCommand}"
                    Padding="16,10"
                    Background="#2A2A3E"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Margin="0,0,8,0">
                <Button.Resources>
                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                </Button.Resources>
            </Button>

            <Button Content="💾 Mentés"
                    Command="{Binding SaveCommand}"
                    Padding="20,10"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#7C3AED"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#6D28D9"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

        </StackPanel>
    </Grid>
</Window>
